source "https://rubygems.org"

ruby ">= 3.1"

# Plotting backend (the `gnuplot` system binary must also be installed).
gem "gnuplot", "~> 2.6"

# csv, json, time, optparse and mkmf are part of the Ruby standard library
# on Ruby 3.1; they become bundled gems in later versions, so pin them here
# to keep `bundle install` working across Ruby versions.
gem "csv"
gem "json"
